# Copy this file to .env and fill values before running docker compose.
# Do not commit .env (it's ignored by git).

# Didit API base URL (default is official production API)
FLOUCNA_DIDIT_API_BASE_URL=https://verification.didit.me

# Workflow UUID from Didit Console -> Workflows (or via GET /v3/workflows/)
FLOUCNA_DIDIT_WORKFLOW_ID=replace_with_your_workflow_uuid

# Didit API key used in x-api-key header
FLOUCNA_DIDIT_API_KEY=replace_with_your_didit_api_key

# Webhook signing secret from Didit dashboard (API & Webhooks section)
FLOUCNA_DIDIT_WEBHOOK_SECRET=replace_with_your_didit_webhook_secret

# ngrok authtoken (dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=replace_with_your_ngrok_authtoken

# Reserved ngrok domain (recommended for stable webhook URL)
# Example: my-floucna.ngrok-free.app
NGROK_DOMAIN=replace_with_your_reserved_ngrok_domain

# Optional explicit webhook URL override.
# If omitted, compose uses: https://${NGROK_DOMAIN}/api/kyc/webhook/didit
# FLOUCNA_DIDIT_WEBHOOK_URL=https://your-public-domain-or-tunnel/api/kyc/webhook/didit

# Where Didit redirects the user after verification in browser
FLOUCNA_DIDIT_CALLBACK_URL=http://localhost:3000/kyc
